# CRX Cloud - Environment Configuration
APP_ENV=dev

# Panel
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=CRX Cloud
NEXT_PUBLIC_BRAND_DOMAIN=crx.team

# Backend API
API_HOST=0.0.0.0
API_PORT=8080
SECRET_KEY=change-me-in-production
DATABASE_URL=postgresql://crxcloud:crxcloud@localhost:5432/crxcloud

# CRX Team Bridge (Vito integration)
CRX_TEAM_API_URL=http://localhost:8000
CRX_TEAM_API_KEY=

# Kubernetes (optional - for managed clusters)
KUBECONFIG_PATH=~/.kube/config

# SSH (optional - for VM management)
SSH_KEY_PATH=~/.ssh/id_rsa

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Backup Storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=crx-cloud-backups
